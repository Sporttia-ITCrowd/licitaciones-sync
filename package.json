{
  "name": "licitaciones-sync",
  "version": "0.1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "sync": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@google-cloud/pino-logging-gcp-config": "^1.1.1",
    "drizzle-orm": "^0.44.6",
    "pino": "^10.0.0",
    "postgres": "^3.4.7",
    "sax": "^1.4.1",
    "undici": "^7.18.0",
    "yauzl": "^3.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/sax": "^1.2.7",
    "@types/yauzl": "^2.10.3",
    "drizzle-kit": "^0.31.5",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
