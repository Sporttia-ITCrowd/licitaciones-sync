# PostgreSQL connection string
# Local default: postgres://postgres:postgres@localhost:5432/licitaciones
# Cloud SQL via Unix socket: postgres://USER:PASS@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/licitaciones

# Optional: Cloud SQL instance connection name (when running in Cloud Run)
# Format: PROJECT:REGION:INSTANCE
# CLOUDSQL_INSTANCE=

# Logging
LOG_LEVEL=info
GOOGLE_CLOUD_PROJECT=

# PLACSP
PLACSP_USER_AGENT=sporttia-licitaciones-sync/1.0 (rruano@sporttia.com)

# Sync
TMP_DIR=./tmp/placsp
BATCH_SIZE=500

# Locking
LOCK_HEARTBEAT_INTERVAL_MS=60000
LOCK_STALE_AFTER_MS=1800000

# Migrations: set to "true" to run drizzle migrations on startup
RUN_MIGRATIONS=false
